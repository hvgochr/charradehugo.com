---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Footer from "@/components/Footer.astro";
import type { StructuredDataSchema } from "@/lib/structuredData";
import type { Locale } from "@/lib/i18n";
import { getLocaleFromUrl } from "@/lib/i18n";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  articleDate?: Date;
  articleModified?: Date;
  structuredData?: StructuredDataSchema;
}

const {
  title,
  description,
  ogImage,
  articleDate,
  articleModified,
  structuredData,
} = Astro.props;

const locale: Locale = getLocaleFromUrl(Astro.url);
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  articleDate={articleDate}
  articleModified={articleModified}
  structuredData={structuredData}
>
  <main>
    <div class="p-4 sm:pt-8 sm:px-12 pb-20 min-h-dvh">
      <slot />
    </div>
  </main>
  <Footer locale={locale} />
</BaseLayout>
