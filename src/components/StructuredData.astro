---
import type { StructuredDataSchema } from "@/lib/structuredData";

interface Props {
  schema: StructuredDataSchema;
}

const { schema } = Astro.props;

const schemaArray = (Array.isArray(schema) ? schema : [schema]).filter(Boolean);
---

{
  schemaArray.map((item) => (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(item)}
    />
  ))
}
