---
type Props = {
  className?: string;
  size?: "default" | "large";
};

const { size = "default", className } = Astro.props;
---

<h1
  class:list={[
    "font-bold text-white text-balance",
    size === "large" &&
      "text-7xl md:text-[120px] lg:text-[160px] tracking-tighter",
    size === "default" && "text-4xl md:text-6xl xl:text-8xl tracking-tight",
    className,
  ]}
>
  <slot />
</h1>
