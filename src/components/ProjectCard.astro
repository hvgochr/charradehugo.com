---
import { Image } from "astro:assets";
import { formatDate } from "@/lib/utils";
import { getSlug, getLocaleFromUrl } from "@/lib/i18n";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  basePath?: string;
}

const { project, basePath = "/projects" } = Astro.props;
const slug = getSlug(project.id);
const dateLocale = getLocaleFromUrl(Astro.url) === "fr" ? "fr-FR" : "en-US";
---

<a
  href={`${basePath}/${slug}`}
  class="block group overflow-hidden rounded-lg border border-zinc-800 hover:border-zinc-700 transition-all duration-300"
>
  <div class="aspect-video overflow-hidden bg-zinc-900">
    <Image
      src={project.data.cover}
      alt={project.data.coverAlt}
      width={800}
      height={400}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
    />
  </div>
  <div class="p-4 space-y-2">
    <h2
      class="text-lg font-medium text-zinc-200 group-hover:text-white transition-colors"
    >
      {project.data.title}
    </h2>
    <p class="text-sm text-zinc-300 line-clamp-2">
      {project.data.description}
    </p>
    <p class="text-xs text-zinc-400">
      {formatDate(project.data.pubDate, dateLocale)}
    </p>
  </div>
</a>
