---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["flex items-center justify-center gap-12", className]}>
  <div
    id="nav-desktop"
    class="hidden lg:flex gap-4 nav-content"
    data-state="closed"
  >
    <slot />
  </div>

  <dialog
    id="nav-mobile"
    aria-label="Navigation menu"
    aria-modal="true"
    class="lg:hidden absolute z-50 w-full h-full flex flex-col gap-4 top-0 bg-zinc-900/20 backdrop-blur-md nav-dialog"
    data-state="closed"
  >
    <div
      class="fixed bottom-20 sm:bottom-32 left-4 sm:left-8 flex flex-col items-start justify-center gap-4"
    >
      <a
        href="/about"
        class="mobile-link w-fit flex items-center justify-center gap-3 text-lg sm:text-2xl text-zinc-100 cursor-pointer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            fill="currentColor"
            d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2S2 6.477 2 12c0 1.6.376 3.112 1.043 4.453c.178.356.237.763.134 1.148l-.595 2.226a1.3 1.3 0 0 0 1.591 1.592l2.226-.596a1.634 1.634 0 0 1 1.149.133A9.958 9.958 0 0 0 12 22"
            opacity=".5"></path>
          <path
            fill="currentColor"
            d="M7.5 11.11c0 1.368 1.319 2.804 2.529 3.833c.823.7 1.235 1.05 1.971 1.05s1.148-.35 1.971-1.05c1.21-1.03 2.529-2.465 2.529-3.834c0-2.677-2.475-3.676-4.5-1.608c-2.025-2.068-4.5-1.069-4.5 1.608"
          ></path>
        </svg>
        About
      </a>

      <a
        href="/blog"
        class="mobile-link w-fit flex items-center justify-center gap-3 text-lg sm:text-2xl text-zinc-100 cursor-pointer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            fill="currentColor"
            fill-rule="evenodd"
            d="m20.83 10.715l-.518 1.932c-.605 2.255-.907 3.383-1.592 4.114a4 4 0 0 1-2.01 1.161c-.097.023-.195.04-.295.052c-.915.113-2.032-.186-4.064-.73c-2.255-.605-3.383-.907-4.114-1.592a4 4 0 0 1-1.161-2.011c-.228-.976.074-2.103.679-4.358l.517-1.932l.244-.905c.455-1.666.761-2.583 1.348-3.21a4 4 0 0 1 2.01-1.16c.976-.228 2.104.074 4.36.679c2.254.604 3.382.906 4.113 1.59a4 4 0 0 1 1.161 2.012c.228.976-.075 2.103-.679 4.358m-9.778-.91a.75.75 0 0 1 .919-.53l4.83 1.295a.75.75 0 1 1-.389 1.448l-4.83-1.294a.75.75 0 0 1-.53-.918m-.776 2.898a.75.75 0 0 1 .918-.53l2.898.777a.75.75 0 1 1-.388 1.448l-2.898-.776a.75.75 0 0 1-.53-.919"
            clip-rule="evenodd"></path>
          <path
            fill="currentColor"
            d="M16.415 17.975a4 4 0 0 1-1.068 1.677c-.731.685-1.859.987-4.114 1.591s-3.383.907-4.358.679a4 4 0 0 1-2.011-1.161c-.685-.731-.988-1.859-1.592-4.114l-.517-1.932c-.605-2.255-.907-3.383-.68-4.358a4 4 0 0 1 1.162-2.011c.731-.685 1.859-.987 4.114-1.592c.426-.114.813-.218 1.165-.309l-.244.906l-.517 1.932c-.605 2.255-.907 3.382-.68 4.358a4 4 0 0 0 1.162 2.011c.731.685 1.859.987 4.114 1.592c2.032.544 3.149.843 4.064.73"
            opacity=".5"></path>
        </svg>
        Blog
      </a>

      <a
        href="/projects"
        class="mobile-link w-fit flex items-center justify-center gap-3 text-lg sm:text-2xl text-zinc-100 cursor-pointer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M3.35791 12.7787C2.74772 13.7201 2.99956 15.0291 3.50323 17.647C3.8658 19.5316 4.04709 20.4738 4.67523 21.0991C4.8382 21.2614 5.02054 21.4052 5.2186 21.5277C5.98195 21.9999 6.99539 21.9999 9.02227 21.9999H15.9777C18.0046 21.9999 19.0181 21.9999 19.7814 21.5277C19.9795 21.4052 20.1618 21.2614 20.3248 21.0991C20.9529 20.4738 21.1342 19.5316 21.4968 17.647C22.0004 15.0291 22.2523 13.7201 21.6421 12.7787C21.4864 12.5384 21.2943 12.321 21.0721 12.1332C20.2011 11.3975 18.7933 11.3975 15.9777 11.3975H9.02227C6.20667 11.3975 4.79888 11.3975 3.92792 12.1332C3.70566 12.321 3.51363 12.5384 3.35791 12.7787ZM9.69518 17.1806C9.69518 16.7814 10.0376 16.4577 10.4601 16.4577H14.5398C14.9622 16.4577 15.3047 16.7814 15.3047 17.1806C15.3047 17.5798 14.9622 17.9035 14.5398 17.9035H10.4601C10.0376 17.9035 9.69518 17.5798 9.69518 17.1806Z"
            fill="currentColor"></path>
          <path
            opacity="0.5"
            d="M3.5762 12.4846C3.68271 12.3586 3.80034 12.241 3.92792 12.1332C4.79888 11.3975 6.20667 11.3975 9.02227 11.3975H15.9777C18.7933 11.3975 20.2011 11.3975 21.0721 12.1332C21.2 12.2413 21.3179 12.3592 21.4247 12.4857V9.75579C21.4247 8.84687 21.4247 8.09279 21.3394 7.49156C21.2494 6.85704 21.0531 6.29458 20.5839 5.83245C20.5074 5.75707 20.4266 5.68552 20.342 5.61807C19.8302 5.21023 19.2167 5.04345 18.5222 4.96608C17.8531 4.89155 17.0102 4.89157 15.9769 4.89158L15.6242 4.89158C14.6421 4.89158 14.29 4.88587 13.9711 4.80533C13.7837 4.75802 13.604 4.69195 13.4352 4.60878C13.151 4.46867 12.9033 4.25762 12.2077 3.64132L11.7336 3.22128C11.5345 3.04489 11.3987 2.9245 11.2531 2.81755C10.6284 2.35879 9.86779 2.08132 9.07145 2.01534C8.88602 1.99998 8.6968 1.99999 8.41356 2.00002L8.29714 2.00001C7.65647 1.9999 7.23365 1.99983 6.86652 2.0612C5.26167 2.32947 3.96392 3.45143 3.64782 4.93575C3.57591 5.27344 3.57602 5.66035 3.57619 6.21853L3.5762 12.4846Z"
            fill="currentColor"></path>
        </svg>
        Projects
      </a>

      <a
        href="/contact"
        class="mobile-link w-fit flex items-center justify-center gap-3 text-lg sm:text-2xl text-zinc-100 cursor-pointer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M24 5C24 6.65685 22.6569 8 21 8C19.3431 8 18 6.65685 18 5C18 3.34315 19.3431 2 21 2C22.6569 2 24 3.34315 24 5Z"
            fill="currentColor"></path>
          <path
            d="M17.2339 7.46394L15.6973 8.74444C14.671 9.59966 13.9585 10.1915 13.357 10.5784C12.7747 10.9529 12.3798 11.0786 12.0002 11.0786C11.6206 11.0786 11.2258 10.9529 10.6435 10.5784C10.0419 10.1915 9.32941 9.59966 8.30315 8.74444L5.92837 6.76546C5.57834 6.47377 5.05812 6.52106 4.76643 6.87109C4.47474 7.22112 4.52204 7.74133 4.87206 8.03302L7.28821 10.0465C8.2632 10.859 9.05344 11.5176 9.75091 11.9661C10.4775 12.4334 11.185 12.7286 12.0002 12.7286C12.8154 12.7286 13.523 12.4334 14.2495 11.9661C14.947 11.5176 15.7372 10.859 16.7122 10.0465L18.3785 8.65795C17.9274 8.33414 17.5388 7.92898 17.2339 7.46394Z"
            fill="currentColor"></path>
          <path
            d="M18.4538 6.58719C18.7362 6.53653 19.0372 6.63487 19.234 6.87109C19.3965 7.06614 19.4538 7.31403 19.4121 7.54579C19.0244 7.30344 18.696 6.97499 18.4538 6.58719Z"
            fill="currentColor"></path>
          <path
            opacity="0.5"
            d="M16.9576 3.02099C16.156 3 15.2437 3 14.2 3H9.8C5.65164 3 3.57746 3 2.28873 4.31802C1 5.63604 1 7.75736 1 12C1 16.2426 1 18.364 2.28873 19.682C3.57746 21 5.65164 21 9.8 21H14.2C18.3484 21 20.4225 21 21.7113 19.682C23 18.364 23 16.2426 23 12C23 10.9326 23 9.99953 22.9795 9.1797C22.3821 9.47943 21.7103 9.64773 21 9.64773C18.5147 9.64773 16.5 7.58722 16.5 5.04545C16.5 4.31904 16.6646 3.63193 16.9576 3.02099Z"
            fill="currentColor"></path>
        </svg>
        Contact
      </a>

      <button
        type="button"
        id="nav-close"
        aria-label="Close navigation menu"
        class="mobile-link w-fit flex items-center justify-center gap-3 text-lg sm:text-2xl text-zinc-100 cursor-pointer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            fill="currentColor"
            d="M22 12c0 5.523-4.477 10-10 10S2 17.523 2 12S6.477 2 12 2s10 4.477 10 10"
            opacity=".5"></path>
          <path
            fill="currentColor"
            d="M8.97 8.97a.75.75 0 0 1 1.06 0L12 10.94l1.97-1.97a.75.75 0 1 1 1.06 1.06L13.06 12l1.97 1.97a.75.75 0 0 1-1.06 1.06L12 13.06l-1.97 1.97a.75.75 0 0 1-1.06-1.06L10.94 12l-1.97-1.97a.75.75 0 0 1 0-1.06"
          ></path>
        </svg>
        Close
      </button>
    </div>
  </dialog>

  <button
    type="button"
    id="nav-toggle"
    aria-expanded="false"
    aria-controls="nav-mobile"
    aria-label="Open navigation menu"
    class="h-fit text-white cursor-pointer hover:outline-2 focus-visible:outline-2 outline-offset-1 outline-zinc-100/20 focus-visible:outline-white rounded-lg"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="32"
      height="32"
      viewBox="0 0 24 24"
      aria-hidden="true"
      class="nav-icon transition-all duration-300 ease-in-out"
    >
      <path
        fill="currentColor"
        d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2S2 6.477 2 12s4.477 10 10 10"
        opacity=".5"></path>
      <path
        fill="currentColor"
        d="M13.024 14.56c.493-.197.739-.296.932-.465c.05-.043.096-.09.139-.139c.17-.193.268-.44.465-.932c.924-2.31 1.386-3.465.938-4.124a1.5 1.5 0 0 0-.398-.398c-.66-.448-1.814.014-4.124.938c-.493.197-.74.295-.933.465c-.049.043-.095.09-.138.139c-.17.193-.268.44-.465.932c-.924 2.31-1.386 3.464-.938 4.124a1.5 1.5 0 0 0 .398.398c.66.448 1.814-.014 4.124-.938"
      ></path>
    </svg>
  </button>
</div>

<style>
  .nav-content {
    animation: fadeIn 0.5s ease-in-out;
  }

  .nav-content[data-state="closed"] {
    display: none !important;
  }

  .nav-content[data-state="closing"] {
    animation: fadeOut 0.5s ease-in-out;
  }

  .nav-dialog {
    display: none;
    animation: fadeIn 0.25s ease-in-out;
  }

  @media (max-width: 1023px) {
    .nav-dialog[data-state="open"],
    .nav-dialog[data-state="closing"] {
      display: flex;
    }
  }

  .nav-dialog[data-state="closing"] {
    animation: fadeOut 0.25s ease-in-out;
  }

  .mobile-link {
    animation: slideUp 0.3s ease-out forwards;
    opacity: 0;
    transform: translateY(100px);
  }

  .nav-dialog[data-state="open"] .mobile-link {
    animation: slideUp 0.3s ease-out forwards;
  }

  .nav-dialog[data-state="open"] .mobile-link:nth-child(1) {
    animation-delay: 0.05s;
  }

  .nav-dialog[data-state="open"] .mobile-link:nth-child(2) {
    animation-delay: 0.1s;
  }

  .nav-dialog[data-state="open"] .mobile-link:nth-child(3) {
    animation-delay: 0.15s;
  }

  .nav-dialog[data-state="open"] .mobile-link:nth-child(4) {
    animation-delay: 0.2s;
  }

  .nav-dialog[data-state="closing"] .mobile-link {
    animation: slideDown 0.3s ease-in forwards;
  }

  .nav-icon[data-state="open"] {
    transform: rotate(90deg);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      filter: blur(20px);
    }
    to {
      opacity: 1;
      filter: blur(0px);
    }
  }

  @keyframes fadeOut {
    from {
      opacity: 1;
      filter: blur(0px);
    }
    to {
      opacity: 0;
      filter: blur(20px);
    }
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(100px);
      filter: blur(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0px);
      filter: blur(0px);
    }
  }

  @keyframes slideDown {
    from {
      opacity: 1;
      transform: translateY(0px);
      filter: blur(0px);
    }
    to {
      opacity: 0;
      transform: translateY(100px);
      filter: blur(20px);
    }
  }
</style>

<script>
  const toggle = document.getElementById("nav-toggle");
  const close = document.getElementById("nav-close");
  const desktop = document.getElementById("nav-desktop");
  const mobile = document.getElementById("nav-mobile") as HTMLDialogElement;
  const icon = toggle?.querySelector(".nav-icon");

  let isOpen = false;

  function openNav() {
    isOpen = true;
    toggle?.setAttribute("aria-expanded", "true");
    desktop?.setAttribute("data-state", "open");
    mobile?.setAttribute("data-state", "open");
    icon?.setAttribute("data-state", "open");

    // Move focus to the first focusable element inside the dialog
    const firstLink = mobile?.querySelector<HTMLElement>("a, button");
    firstLink?.focus();
  }

  function closeNav() {
    isOpen = false;
    toggle?.setAttribute("aria-expanded", "false");
    desktop?.setAttribute("data-state", "closing");
    mobile?.setAttribute("data-state", "closing");
    icon?.setAttribute("data-state", "closed");

    setTimeout(() => {
      desktop?.setAttribute("data-state", "closed");
      mobile?.setAttribute("data-state", "closed");
    }, 250);

    // Return focus to the toggle button
    toggle?.focus();
  }

  toggle?.addEventListener("click", () => {
    if (isOpen) {
      closeNav();
    } else {
      openNav();
    }
  });

  close?.addEventListener("click", closeNav);
  mobile?.addEventListener("click", (e) => {
    if (e.target === mobile) {
      closeNav();
    }
  });

  // Close on Escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && isOpen) {
      closeNav();
    }
  });
</script>
