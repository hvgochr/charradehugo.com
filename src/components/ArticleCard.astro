---
import { Image } from "astro:assets";
import { formatDate } from "@/lib/utils";
import type { CollectionEntry } from "astro:content";

type Props = {
  article: CollectionEntry<"articles">;
};

const { article } = Astro.props;
---

<a href={`/blog/${article.id}`} class="flex flex-col sm:flex-row gap-4 group">
  <div
    class="sm:w-48 sm:h-32 w-full h-48 shrink-0 overflow-hidden rounded-md bg-zinc-900"
  >
    <Image
      src={article.data.cover}
      alt={article.data.coverAlt}
      width={800}
      height={400}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
    />
  </div>
  <div class="flex-1 space-y-2 min-w-0">
    <h2
      class="text-xl xl:text-2xl text-zinc-300 group-hover:text-white text-balance font-medium underline group-hover:underline-offset-2 decoration-transparent group-hover:decoration-zinc-500"
    >
      {article.data.title}
    </h2>
    <p class="text-base text-zinc-400 line-clamp-2">
      {article.data.description}
    </p>
    <p class="text-sm text-zinc-500">
      {formatDate(article.data.pubDate)}
    </p>
  </div>
</a>
