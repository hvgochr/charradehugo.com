---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
---

{
  headings.length > 0 && (
    <nav class="hidden xl:block fixed top-32 right-8 w-64 max-h-[calc(100vh-10rem)] overflow-y-auto">
      <div class="space-y-2">
        <h2 class="text-lg font-semibold text-zinc-200 tracking-wide mb-4">
          On this page
        </h2>
        <ul class="space-y-2 text-sm">
          {headings.map((heading) => (
            <li
              class:list={[
                "toc-item",
                heading.depth === 3 && "pl-4",
                heading.depth === 4 && "pl-8",
              ]}
            >
              <a
                href={`#${heading.slug}`}
                class="block text-zinc-500 hover:text-zinc-200 transition-colors toc-link"
                data-heading-id={heading.slug}
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  )
}

<style>
  .toc-link.active {
    color: rgb(244 244 245);
    font-weight: 500;
  }

  nav::-webkit-scrollbar {
    width: 4px;
  }

  nav::-webkit-scrollbar-track {
    background: transparent;
  }

  nav::-webkit-scrollbar-thumb {
    background: rgb(63 63 70);
    border-radius: 2px;
  }

  nav::-webkit-scrollbar-thumb:hover {
    background: rgb(82 82 91);
  }
</style>

<script>
  function initTableOfContents() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.getAttribute("id");
          const tocLink = document.querySelector(
            `.toc-link[data-heading-id="${id}"]`
          );

          if (entry.isIntersecting) {
            document.querySelectorAll(".toc-link").forEach((link) => {
              link.classList.remove("active");
            });
            tocLink?.classList.add("active");
          }
        });
      },
      {
        rootMargin: "-100px 0px -66%",
        threshold: 1,
      }
    );

    document.querySelectorAll("h2[id], h3[id], h4[id]").forEach((heading) => {
      observer.observe(heading);
    });
  }

  document.addEventListener("astro:page-load", initTableOfContents);
</script>
