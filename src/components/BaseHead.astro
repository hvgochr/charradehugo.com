---
import "../styles/global.css";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import StructuredData from "./StructuredData.astro";
import type { StructuredDataSchema } from "@/lib/structuredData";
import { getLocaleFromUrl, getLocalePath } from "@/lib/i18n";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  articleDate?: Date;
  articleModified?: Date;
  structuredData?: StructuredDataSchema;
}

const {
  title,
  description,
  ogImage,
  articleDate,
  articleModified,
  structuredData,
} = Astro.props;

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || Astro.url.origin
);
const socialImageURL = new URL(
  ogImage ?? "/og-image.png",
  Astro.site || Astro.url.origin
).href;

const siteOrigin = (Astro.site || Astro.url.origin)
  .toString()
  .replace(/\/$/, "");
const locale = getLocaleFromUrl(Astro.url);
const ogLocale = locale === "fr" ? "fr_FR" : "en_US";

const defaultDescription =
  locale === "fr"
    ? "Développeur full-stack spécialisé dans la création d'applications web rapides et évolutives avec Symfony, Laravel et les frameworks JavaScript modernes."
    : "Full-stack developer building fast and scalable web applications with Symfony, Laravel and modern JavaScript frameworks.";

const barePath = Astro.url.pathname.replace(/^\/fr(\/|$)/, "/");
const enURL = `${siteOrigin}${getLocalePath("en", barePath)}`;
const frURL = `${siteOrigin}${getLocalePath("fr", barePath)}`;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" type="application/xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${title} RSS Feed`}
  href="/rss.xml"
/>
<link rel="author" href={Astro.site || Astro.url.origin} />
<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-geist" preload />

<ClientRouter />

<link rel="canonical" href={canonicalURL} />

<link rel="alternate" hreflang="en" href={enURL} />
<link rel="alternate" hreflang="fr" href={frURL} />
<link rel="alternate" hreflang="x-default" href={enURL} />

<title>{title}</title>
<meta name="description" content={description ?? defaultDescription} />
<meta name="application-name" content={title} />
<meta name="creator" content="Hugo Charrade" />
<meta
  name="keywords"
  content="Hugo Charrade,Full-stack developer,Symfony,Laravel,JavaScript,APIs,Docker,Web Development,Portfolio,Blog,Tech,Software Engineer,Automation"
/>
<meta name="author" content="Hugo Charrade" />
<meta name="robots" content="index, follow" />
<meta property="profile:first_name" content="Hugo" />
<meta property="profile:last_name" content="Charrade" />

<meta property="og:title" content={title} />
<meta property="og:description" content={description ?? defaultDescription} />
<meta property="og:url" content={Astro.url} />
<meta property="og:site_name" content="Hugo Charrade Portfolio" />
<meta property="og:locale" content={ogLocale} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image" content={socialImageURL} />
<meta property="og:type" content={articleDate ? "article" : "website"} />
{
  articleDate && (
    <meta
      property="article:published_time"
      content={articleDate.toISOString()}
    />
  )
}
{
  articleModified && (
    <meta
      property="article:modified_time"
      content={articleModified.toISOString()}
    />
  )
}
{articleDate && <meta property="article:author" content="Hugo Charrade" />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:creator" content="@hvgochr" />
<meta name="twitter:title" content={title} />
<meta name="twitter:image:type" content="image/png" />
<meta name="twitter:image:width" content="1200" />
<meta name="twitter:image:height" content="630" />
<meta name="twitter:image" content={socialImageURL} />
<meta name="twitter:description" content={description ?? defaultDescription} />
<meta name="twitter:url" content={Astro.url} />

{structuredData && <StructuredData schema={structuredData} />}
