---
import type { WarpPattern } from "@paper-design/shaders";

interface Props {
  colors?: string[];
  pattern?: WarpPattern;
  patternScale?: number;
  distortion?: number;
  swirl?: number;
  swirlIterations?: number;
  softness?: number;
  proportion?: number;
  speed?: number;
  scale?: number;
  rotation?: number;
}

const {
  colors = ["#0a0a0a", "#1a1a2e", "#16213e", "#0f3460"],
  pattern = "checks",
  patternScale = 0.5,
  distortion = 0.3,
  swirl = 0.2,
  swirlIterations = 10,
  softness = 0.8,
  proportion = 0.5,
  speed = 0.5,
  scale = 1,
  rotation = 0,
} = Astro.props;

const config = JSON.stringify({
  colors,
  shape: pattern,
  shapeScale: patternScale,
  distortion,
  swirl,
  swirlIterations,
  softness,
  proportion,
  speed,
  scale,
  rotation,
});
---

<div class="warp-background" data-config={config}></div>

<style>
  .warp-background {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }

  .warp-background :global(canvas) {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script>
  import {
    ShaderMount,
    warpFragmentShader,
    getShaderColorFromString,
    getShaderNoiseTexture,
    WarpPatterns,
    type WarpParams,
    type WarpUniforms,
  } from "@paper-design/shaders";

  async function initWarpBackground(container: HTMLElement) {
    const configAttr = container.dataset.config;
    if (!configAttr) return;

    const config = JSON.parse(configAttr) as WarpParams & { shape: string };
    const colors = (config.colors ?? []).map(getShaderColorFromString);

    const noiseTexture = getShaderNoiseTexture();
    await new Promise<void>((resolve) => {
      if (noiseTexture.complete) {
        resolve();
      } else {
        noiseTexture.onload = () => resolve();
      }
    });

    const uniforms: WarpUniforms = {
      u_colors: colors,
      u_colorsCount: colors.length,
      u_proportion: config.proportion ?? 0.5,
      u_softness: config.softness ?? 0.8,
      u_shape: WarpPatterns[config.shape as keyof typeof WarpPatterns] ?? 0,
      u_shapeScale: config.shapeScale ?? 0.5,
      u_distortion: config.distortion ?? 0.3,
      u_swirl: config.swirl ?? 0.2,
      u_swirlIterations: config.swirlIterations ?? 10,
      u_noiseTexture: noiseTexture,
      u_scale: config.scale ?? 1,
      u_rotation: config.rotation ?? 0,
      u_offsetX: 0,
      u_offsetY: 0,
    };

    new ShaderMount(
      container,
      warpFragmentShader,
      uniforms,
      { alpha: true },
      config.speed ?? 0.5
    );
  }

  document.querySelectorAll<HTMLElement>(".warp-background").forEach((el) => {
    initWarpBackground(el);
  });
</script>
