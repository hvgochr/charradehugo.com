---
import ContentLayout from "@/layouts/ContentLayout.astro";
import Prose from "@/components/Prose.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import { render } from "astro:content";
import { Image } from "astro:assets";
import { formatDate } from "@/lib/utils";
import { getPublishedArticles } from "@/lib/content";
import { getSlug, useTranslations } from "@/lib/i18n";
import {
  createArticleSchema,
  createBreadcrumbSchema,
} from "@/lib/structuredData";

export async function getStaticPaths() {
  const articles = await getPublishedArticles("fr");
  return articles.map((article) => ({
    params: { slug: getSlug(article.id) },
    props: article,
  }));
}

const t = useTranslations("fr");
const article = Astro.props;
const { Content, headings } = await render(article);

const allArticles = (await getPublishedArticles("fr"))
  .filter((a) => a.id !== article.id)
  .slice(0, 3);

const siteUrl = Astro.site?.toString() || Astro.url.origin;
const articleUrl = new URL(`/fr/blog/${getSlug(article.id)}`, siteUrl).href;

const structuredData = [
  createArticleSchema(article, siteUrl, articleUrl),
  createBreadcrumbSchema([
    { name: "Accueil", url: new URL("/fr", siteUrl).href },
    { name: "Blog", url: new URL("/fr/blog", siteUrl).href },
    { name: article.data.title, url: articleUrl },
  ]),
];
---

<ContentLayout
  title={`${article.data.title} - Hugo Charrade, Développeur Full-Stack`}
  description={article.data.description}
  articleDate={article.data.pubDate}
  articleModified={article.data.updateDate}
  structuredData={structuredData}
>
  <div class="max-w-5xl mx-auto">
    <header class="mb-8 space-y-3">
      <p class="text-sm text-zinc-400">
        {formatDate(article.data.pubDate, "fr-FR")}
      </p>
      <h1 class="text-4xl md:text-5xl font-bold text-white text-balance">
        {article.data.title}
      </h1>
      <p class="text-lg text-zinc-300">{article.data.description}</p>
    </header>

    <div class="mb-12 rounded-xl overflow-hidden">
      <Image
        src={article.data.cover}
        alt={article.data.coverAlt}
        width={1200}
        height={600}
        class="w-full h-auto object-cover"
      />
    </div>

    <div class="flex gap-12">
      <article class="flex-1 min-w-0">
        <Prose>
          <Content />
        </Prose>
      </article>

      <aside class="hidden xl:block w-64 shrink-0">
        <div class="sticky top-8">
          <TableOfContents headings={headings} />
        </div>
      </aside>
    </div>

    {
      allArticles.length > 0 && (
        <div class="mt-16 pt-12 border-t border-zinc-800">
          <h2 class="text-2xl font-semibold text-zinc-200 mb-6">
            {t.blog.recentArticles}
          </h2>
          <ul class="space-y-6">
            {allArticles.map((relatedArticle) => (
              <li>
                <ArticleCard article={relatedArticle} basePath="/fr/blog" />
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <div class="mt-12 pt-8 border-t border-zinc-800">
      <a
        href="/fr/blog"
        class="inline-flex items-center gap-2 text-zinc-400 hover:text-zinc-200 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <title>Back Arrow Icon</title>
          <path
            opacity="0.5"
            d="M12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22Z"
            fill="currentColor"></path><path
            d="M10.4697 8.46967C10.7626 8.17678 11.2374 8.17678 11.5303 8.46967C11.8232 8.76256 11.8232 9.23744 11.5303 9.53033L9.81066 11.25H16C16.4142 11.25 16.75 11.5858 16.75 12C16.75 12.4142 16.4142 12.75 16 12.75H9.81066L11.5303 14.4697C11.8232 14.7626 11.8232 15.2374 11.5303 15.5303C11.2374 15.8232 10.7626 15.8232 10.4697 15.5303L7.46967 12.5303C7.17678 12.2374 7.17678 11.7626 7.46967 11.4697L10.4697 8.46967Z"
            fill="currentColor"></path></svg
        >
        {t.blog.backToBlog}
      </a>
    </div>
  </div>
</ContentLayout>
