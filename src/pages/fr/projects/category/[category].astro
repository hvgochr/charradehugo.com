---
import ContentLayout from "@/layouts/ContentLayout.astro";
import H1 from "@/components/H1.astro";
import CategoryFilter from "@/components/CategoryFilter.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { getPublishedProjects, getCategories } from "@/lib/content";
import { useTranslations } from "@/lib/i18n";

export async function getStaticPaths() {
  const projects = await getPublishedProjects("fr");
  const allCategories = getCategories(projects);

  return allCategories.map((category) => ({
    params: { category },
    props: {
      projects: projects.filter((project) =>
        project.data.categories.includes(category)
      ),
      allCategories,
    },
  }));
}

const t = useTranslations("fr");
const { category } = Astro.params;
const { projects, allCategories } = Astro.props;
---

<ContentLayout
  title={`${t.projects.categoryPrefix}: ${category} - Hugo Charrade, Développeur Full-Stack`}
  description={`Projets sur ${category} par Hugo Charrade, développeur Full-Stack spécialisé dans la création d'applications web rapides et évolutives.`}
>
  <H1>{t.projects.categoryPrefix}: {category}</H1>

  <div class="space-y-4 sm:space-y-12 mt-4">
    <CategoryFilter
      categories={allCategories}
      currentCategory={category}
      basePath="/fr/projects"
    />

    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        projects.map((project) => (
          <li>
            <ProjectCard project={project} basePath="/fr/projects" />
          </li>
        ))
      }
    </ul>
  </div>
</ContentLayout>
