---
import BaseLayout from "@/layouts/BaseLayout.astro";
import H1 from "@/components/H1.astro";
import Button from "@/components/Button.astro";
import { createBreadcrumbSchema } from "@/lib/structuredData";
import { useTranslations } from "@/lib/i18n";

const t = useTranslations("fr");
const siteUrl = Astro.site?.toString() || Astro.url.origin;

const structuredData = [
  createBreadcrumbSchema([
    { name: "Accueil", url: new URL("/fr", siteUrl).href },
    { name: "404", url: new URL("/fr/404", siteUrl).href },
  ]),
];
---

<BaseLayout title={t.notFound.metaTitle} structuredData={structuredData}>
  <main>
    <div class="w-full min-h-dvh flex items-center justify-center px-4 sm:px-8">
      <div class="max-w-2xl w-full text-center">
        <div class="mb-8 flex flex-col items-center">
          <p class="text-zinc-400 text-xl sm:text-2xl mb-4">
            {t.notFound.code}
          </p>
          <H1 size="default">{t.notFound.title}</H1>
          <p class="mt-6 text-zinc-300 text-lg sm:text-xl max-w-lg mx-auto">
            {t.notFound.message}
          </p>
        </div>

        <div
          class="flex flex-col sm:flex-row gap-4 justify-center items-center"
        >
          <Button href="/fr" variant="primary">{t.notFound.backHome}</Button>
          <Button href="/fr/blog" variant="secondary"
            >{t.notFound.readBlog}</Button
          >
          <Button href="/fr/projects" variant="secondary"
            >{t.notFound.viewProjects}</Button
          >
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
