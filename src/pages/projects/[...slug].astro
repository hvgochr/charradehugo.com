---
import ContentLayout from "@/layouts/ContentLayout.astro";
import Prose from "@/components/Prose.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { render } from "astro:content";
import { Image } from "astro:assets";
import { formatDate } from "@/lib/utils";
import { createBreadcrumbSchema } from "@/lib/structuredData";
import { getPublishedProjects } from "@/lib/content";
import { getSlug, useTranslations } from "@/lib/i18n";

export async function getStaticPaths() {
  const projects = await getPublishedProjects("en");
  return projects.map((project) => ({
    params: { slug: getSlug(project.id) },
    props: project,
  }));
}

const t = useTranslations("en");
const project = Astro.props;
const { Content, headings } = await render(project);

const allProjects = (await getPublishedProjects("en"))
  .filter((p) => p.id !== project.id)
  .slice(0, 3);

const siteUrl = Astro.site?.toString() || Astro.url.origin;
const projectUrl = new URL(`/projects/${getSlug(project.id)}`, siteUrl).href;

const structuredData = createBreadcrumbSchema([
  { name: "Home", url: new URL("/", siteUrl).href },
  { name: "Projects", url: new URL("/projects", siteUrl).href },
  { name: project.data.title, url: projectUrl },
]);
---

<ContentLayout
  title={`${project.data.title} - Hugo Charrade, Full-Stack Developer`}
  description={project.data.description}
  articleDate={project.data.pubDate}
  articleModified={project.data.updateDate}
  structuredData={structuredData}
>
  <div class="max-w-6xl mx-auto">
    <header class="mb-8 space-y-3">
      <p class="text-sm text-zinc-400">
        {formatDate(project.data.pubDate, "en-US")}
      </p>
      <h1 class="text-4xl md:text-5xl font-bold text-white text-balance">
        {project.data.title}
      </h1>
      <p class="text-lg text-zinc-300">{project.data.description}</p>
    </header>

    <div class="mb-12 rounded-xl overflow-hidden">
      <Image
        src={project.data.cover}
        alt={project.data.coverAlt}
        width={1200}
        height={600}
        class="w-full h-auto object-cover"
      />
    </div>

    <div class="flex gap-12">
      <article class="flex-1 min-w-0">
        <Prose>
          <Content />
        </Prose>
      </article>

      <aside class="hidden xl:block w-64 shrink-0">
        <div class="sticky top-8">
          <TableOfContents headings={headings} />
        </div>
      </aside>
    </div>

    {
      allProjects.length > 0 && (
        <div class="mt-16 pt-12 border-t border-zinc-800">
          <h2 class="text-2xl font-semibold text-zinc-200 mb-6">
            {t.projects.recentProjects}
          </h2>
          <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {allProjects.map((relatedProject) => (
              <li>
                <ProjectCard project={relatedProject} basePath="/projects" />
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <div class="mt-12 pt-8 border-t border-zinc-800">
      <a
        href="/projects"
        class="inline-flex items-center gap-2 text-zinc-400 hover:text-zinc-200 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <title>Back Arrow Icon</title>
          <path
            opacity="0.5"
            d="M12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22Z"
            fill="currentColor"></path><path
            d="M10.4697 8.46967C10.7626 8.17678 11.2374 8.17678 11.5303 8.46967C11.8232 8.76256 11.8232 9.23744 11.5303 9.53033L9.81066 11.25H16C16.4142 11.25 16.75 11.5858 16.75 12C16.75 12.4142 16.4142 12.75 16 12.75H9.81066L11.5303 14.4697C11.8232 14.7626 11.8232 15.2374 11.5303 15.5303C11.2374 15.8232 10.7626 15.8232 10.4697 15.5303L7.46967 12.5303C7.17678 12.2374 7.17678 11.7626 7.46967 11.4697L10.4697 8.46967Z"
            fill="currentColor"></path></svg
        >
        {t.projects.backToProjects}
      </a>
    </div>
  </div>
</ContentLayout>
