---
import ContentLayout from "@/layouts/ContentLayout.astro";
import Prose from "@/components/Prose.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import { formatDate } from "@/lib/utils";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: project,
  }));
}

const project = Astro.props;
const { Content, headings } = await render(project);
---

<ContentLayout
  title={`${project.data.title} - Hugo Charrade, Full-Stack Developer`}
  description={project.data.description}
>
  <div class="max-w-6xl mx-auto">
    <header class="mb-8 space-y-3">
      <p class="text-sm text-zinc-500">{formatDate(project.data.pubDate)}</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white text-balance">
        {project.data.title}
      </h1>
      <p class="text-lg text-zinc-400">{project.data.description}</p>
    </header>

    <div class="mb-12 rounded-xl overflow-hidden">
      <Image
        src={project.data.cover}
        alt={project.data.coverAlt}
        width={1200}
        height={600}
        class="w-full h-auto object-cover"
      />
    </div>

    <div class="flex gap-12">
      <article class="flex-1 min-w-0">
        <Prose>
          <Content />
        </Prose>
      </article>

      <aside class="hidden xl:block w-64 shrink-0">
        <div class="sticky top-8">
          <TableOfContents headings={headings} />
        </div>
      </aside>
    </div>
  </div>
</ContentLayout>
