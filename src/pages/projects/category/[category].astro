---
import BaseLayout from "@/layouts/BaseLayout.astro";
import H1 from "@/components/H1.astro";
import Footer from "@/components/Footer.astro";
import { formatDate } from "@/lib/utils";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const projects = (await getCollection("projects")).filter(
    (project) => !project.data.isDraft
  );

  const categories = new Set<string>();
  projects.forEach((project) => {
    project.data.categories.forEach((cat) => categories.add(cat));
  });

  const allCategories = Array.from(categories).sort();

  return allCategories.map((category) => ({
    params: { category },
    props: {
      projects: projects
        .filter((project) => project.data.categories.includes(category))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
      allCategories,
    },
  }));
}

const { category } = Astro.params;
const { projects, allCategories } = Astro.props;
---

<BaseLayout
  title={`Projects: ${category} - Hugo Charrade, Full-Stack Developer`}
  description={`Projects about ${category} by Hugo Charrade, a Full-Stack Developer specializing in building fast and scalable web applications.`}
>
  <main>
    <div class="p-4 sm:pt-8 sm:px-12 pb-20 min-h-dvh">
      <H1>Projects: {category}</H1>

      <div class="space-y-4 sm:space-y-12 mt-4">
        <div class="w-full overflow-x-auto scrollbar-hidden py-2">
          <ul class="flex items-center gap-4 min-w-max px-1">
            <li>
              <a
                href="/projects"
                class="w-fit px-4 py-1 text-sm bg-transparent rounded-full transition-all duration-300 ease-in-out text-zinc-400 hover:text-zinc-200"
              >
                All
              </a>
            </li>
            {
              allCategories.map((cat) => (
                <li>
                  <a
                    href={`/projects/category/${cat}`}
                    class={`w-fit px-4 py-1 text-sm bg-transparent rounded-full transition-all duration-300 ease-in-out ${
                      cat === category
                        ? "text-white bg-zinc-100/20 outline outline-2 outline-offset-2 outline-zinc-100/20"
                        : "text-zinc-400 hover:text-zinc-200"
                    }`}
                  >
                    {cat}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {
            projects.map((project) => (
              <li>
                <a
                  href={`/projects/${project.id}`}
                  class="block group overflow-hidden rounded-lg border border-zinc-800 hover:border-zinc-700 transition-all duration-300"
                >
                  <div class="aspect-video overflow-hidden bg-zinc-900">
                    <Image
                      src={project.data.cover}
                      alt={project.data.coverAlt}
                      width={800}
                      height={400}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                  </div>
                  <div class="p-4 space-y-2">
                    <h2 class="text-lg font-medium text-zinc-200 group-hover:text-white transition-colors">
                      {project.data.title}
                    </h2>
                    <p class="text-sm text-zinc-400 line-clamp-2">
                      {project.data.description}
                    </p>
                    <p class="text-xs text-zinc-500">
                      {formatDate(project.data.pubDate)}
                    </p>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <Footer />
    </div>
  </main>
</BaseLayout>
