---
import BaseLayout from "@/layouts/BaseLayout.astro";
import H1 from "@/components/H1.astro";
import CurrentStatus from "@/components/CurrentStatus.astro";
import Button from "@/components/Button.astro";
import Navigation from "@/components/Navigation.astro";
import MeshGradientBackground from "@/components/MeshGradientBackground.astro";
import { createWebSiteSchema, createPersonSchema } from "@/lib/structuredData";

const siteUrl = Astro.site?.toString() || Astro.url.origin;

const structuredData = [
  createWebSiteSchema(siteUrl),
  createPersonSchema(siteUrl),
];
---

<BaseLayout
  title="Hugo Charrade, Full-Stack Developer - Portfolio"
  structuredData={structuredData}
>
  <main>
    <div
      class="group relative w-full min-h-dvh flex items-center justify-center"
    >
      <div class="absolute w-full h-dvh -z-10">
        <MeshGradientBackground
          colors={["#0a0a0a", "#1c1c1c", "#2d2d2d", "#404040", "#525252"]}
          waveX={0.3}
          waveY={0.2}
          mixing={0.5}
          grainMixer={0}
          grainOverlay={0}
        />
      </div>

      <div
        class="p-4 sm:p-8 absolute w-full h-dvh flex flex-col justify-between z-10"
      >
        <div>
          <H1 size="large">Hugo <br />Charrade</H1>
          <h2 class="mt-2 sm:mt-4 text-zinc-300 text-lg sm:text-2xl max-w-xl">
            Full-Stack Developer specializing in building fast and scalable web
            applications with Symfony, Laravel, and modern JavaScript
            frameworks.
          </h2>
        </div>

        <div>
          <CurrentStatus className="py-4" />
          <div class="mb-2 sm:mb-4 flex items-center justify-between">
            <div class="flex items-center gap-4">
              <Button href="/contact">Get in Touch</Button>
            </div>

            <Navigation>
              <Button href="/about" variant="secondary">About</Button>
              <Button href="/blog" variant="secondary">Blog</Button>
              <Button href="/projects" variant="secondary">Projects</Button>
              <Button href="/contact" variant="secondary">Contact</Button>
            </Navigation>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
