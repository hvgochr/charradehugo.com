---
import ContentLayout from "@/layouts/ContentLayout.astro";
import H1 from "@/components/H1.astro";
import CategoryFilter from "@/components/CategoryFilter.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import { getPublishedArticles, getCategories } from "@/lib/content";
import { useTranslations } from "@/lib/i18n";

const t = useTranslations("en");
const articles = await getPublishedArticles("en");
const categories = getCategories(articles);
---

<ContentLayout title={t.blog.metaTitle} description={t.blog.metaDescription}>
  <H1>{t.blog.h1}</H1>

  <div class="space-y-4 sm:space-y-12 mt-4">
    <CategoryFilter categories={categories} basePath="/blog" />

    <ul class="space-y-6">
      {
        articles.map((article) => (
          <li>
            <ArticleCard article={article} basePath="/blog" />
          </li>
        ))
      }
    </ul>
  </div>
</ContentLayout>
